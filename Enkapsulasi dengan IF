class Mahasiswa:
    def __init__(self, nama, nim):
        self.__nama = nama
        self.__nim = nim

    def getNama(self):
        return self.__nama
    
    def getNim(self):
        return self.__nim
    
    def setNama(self, nama):
        self.__nama = nama

    def setNim(self, nim):
        self.__nim = nim

daftar_mahasiswa = [
    Mahasiswa("Budi", "111"),
    Mahasiswa("Andi", "222")
]

print("DATA AWAL")
for mhs in daftar_mahasiswa:
    print("Nama: {mhs.getNama()} | NIM: {mhs.getNim()}")

print("FITUR GANTI NAMA")
nama_dicari = input("Masukkan nama yang ingin diganti: ")

for mhs in daftar_mahasiswa:
    if mhs.getNama() == nama_dicari:
        nama_baru = input("Masukkan nama pengganti untuk {nama_dicari}: ")
        mhs.setNama(nama_baru) 

print("HASIL DATA AKHIR")
for mhs in daftar_mahasiswa:
    print("Nama: {mhs.getNama()} | NIM: {mhs.getNim()}")
