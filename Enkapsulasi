class Mahasiswa:
    def __init__(self, nama, nim):
        self.__nama = nama
        self.__nim = nim

    def getNama(self):
        return self.__nama
    
    def getNim(self):
        return self.__nim
    
    def setNama(self, nama):
        self.__nama = nama

    def setNim(self, nim):
        self.__nim = nim

mhs1 = Mahasiswa("Budi", "12345")
print("Nama Mahasiswa:", mhs1.getNama())
print("NIM Mahasiswa:", mhs1.getNim())

mhs1.setNama("Andi")
print("Nama Mahasiswa setelah diubah:", mhs1.getNama())
print("NIM Mahasiswa setelah diubah:", mhs1.getNim())
